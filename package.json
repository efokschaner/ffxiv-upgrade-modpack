{
  "name": "ffxiv-upgrade-modpack",
  "version": "0.0.0",
  "private": true,
  "license": "GPL-3.0-or-later",
  "author": "Edmund Fokschaner",
  "type": "module",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "prepare": "lefthook install",
    "build": "vite build",
    "test": "tsx scripts/run-tests.ts",
    "test:watch": "vitest",
    "test:coverage": "tsx scripts/run-tests.ts --coverage",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write ."
  },
  "dependencies": {
    "fflate": "0.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/node": "22.20.0",
    "@vitest/coverage-v8": "4.1.9",
    "lefthook": "2.1.9",
    "tsx": "4.22.4",
    "typescript": "5.4.5",
    "vite": "6.4.3",
    "vitest": "4.1.9"
  }
}
